# =============================================================================
# LinkedIn Bot — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
# =============================================================================

# ── LinkedIn API (required for `post` and `auth` commands) ──────────────────
# Create a LinkedIn Developer App at https://www.linkedin.com/developers/apps/
# Enable: Sign In With LinkedIn using OpenID Connect + Share on LinkedIn APIs
# OAuth scopes needed: openid, profile, w_member_social, email
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8080/callback

# ── DeepSeek API (required) ────────────────────────────────────────────────
# Get your API key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── Post Configuration ─────────────────────────────────────────────────────
MAX_POST_LENGTH=3000
POST_LANGUAGE=en

# ── Database ───────────────────────────────────────────────────────────────
DB_PATH=posts.db

# ── Logging ────────────────────────────────────────────────────────────────
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
